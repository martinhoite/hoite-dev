{
  "name": "@hoite-dev/storybook",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "prebuild": "npm run build --workspace @hoite-dev/ui",
    "build": "storybook build",
    "predev": "npm run build --workspace @hoite-dev/ui",
    "dev": "storybook dev --host storybook.local.hoite.dev --port 6006 --https --ssl-cert ../../ssl/local.hoite.dev.pem --ssl-key ../../ssl/local.hoite.dev-key.pem",
    "format": "biome check --write .",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@hoite-dev/ui": "0.0.0",
    "vue": "^3.5.31"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/vue3-vite": "^10.3.5",
    "@vitejs/plugin-vue": "^6.0.5",
    "storybook": "^10.3.5",
    "storybook-design-token": "^5.0.0",
    "vite": "^7.3.1"
  }
}
