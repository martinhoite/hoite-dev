{
  "name": "@hoite-dev/site-nuxt",
  "private": true,
  "type": "module",
  "engines": {
    "pnpm": ">=10.0.0",
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "pnpm run readme:sync-versions && nuxt build",
    "dev": "nuxt dev",
    "format": "biome check --write . && prettier --write \"**/*.vue\"",
    "format:vue": "prettier --write \"**/*.vue\"",
    "generate": "nuxt generate",
    "lint": "biome check . && eslint \"**/*.vue\"",
    "lint:vue": "eslint \"**/*.vue\"",
    "lint:vue:fix": "eslint \"**/*.vue\" --fix",
    "postinstall": "nuxt prepare",
    "preview": "nuxt preview",
    "readme:check-versions": "node ./scripts/sync-readme-versions.mjs --check",
    "readme:sync-versions": "node ./scripts/sync-readme-versions.mjs",
    "typecheck": "nuxt typecheck"
  },
  "devDependencies": {
    "@csstools/postcss-global-data": "^3.1.0",
    "@modyfi/vite-plugin-yaml": "^1.1.1",
    "@nuxt/devtools": "^3.2.4",
    "@nuxt/eslint": "^1.15.2",
    "eslint": "^9.39.4",
    "postcss-calc": "^10.1.1",
    "postcss-nested": "^7.0.2",
    "postcss-preset-env": "^10.6.1",
    "postcss-reporter": "^7.1.0",
    "prettier": "^3.8.3",
    "vue-tsc": "^3.2.7"
  },
  "dependencies": {
    "@hoite-dev/umbraco-client": "workspace:*",
    "@nuxt/image": "^2.0.0",
    "@pinia/nuxt": "^0.11.3",
    "nuxt": "^4.4.2",
    "nuxt-schema-org": "^5.0.10",
    "ofetch": "^1.5.1",
    "ufo": "^1.6.4",
    "vue": "^3.5.33"
  }
}
