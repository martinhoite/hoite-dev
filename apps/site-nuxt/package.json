{
  "name": "@hoite-dev/site-nuxt",
  "private": true,
  "type": "module",
  "engines": {
    "npm": ">=10.0.0",
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "npm run readme:sync-versions && nuxt build",
    "dev": "nuxt dev",
    "format": "biome check --write .",
    "generate": "nuxt generate",
    "lint": "biome check .",
    "postinstall": "nuxt prepare",
    "preview": "nuxt preview",
    "readme:check-versions": "node ./scripts/sync-readme-versions.mjs --check",
    "readme:sync-versions": "node ./scripts/sync-readme-versions.mjs",
    "typecheck": "nuxt typecheck"
  },
  "devDependencies": {
    "@csstools/postcss-global-data": "^3.1.0",
    "@modyfi/vite-plugin-yaml": "^1.1.1",
    "@nuxt/devtools": "^3.2.4",
    "postcss-calc": "^10.1.1",
    "postcss-nested": "^7.0.2",
    "postcss-preset-env": "^10.6.1",
    "postcss-reporter": "^7.1.0",
    "vue-tsc": "^3.2.6"
  },
  "dependencies": {
    "@hoite-dev/umbraco-client": "0.0.0",
    "@nuxt/image": "^2.0.0",
    "@pinia/nuxt": "^0.11.3",
    "nuxt": "^4.4.2",
    "nuxt-schema-org": "^5.0.10",
    "ofetch": "^1.5.1",
    "vue": "^3.5.31"
  }
}
