{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
    "paths": {
      "@frontend-docs-shared/*": ["../shared/*"],
      "react": ["./node_modules/@types/react"],
      "react/jsx-runtime": ["./node_modules/@types/react/jsx-runtime"]
    },
    "types": ["node", "react"]
  },
  "include": [
    ".storybook/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "../shared/**/*.ts",
    "../shared/**/*.tsx"
  ]
}
