{
  "name": "@hoite-dev/storybook-addon-composition-theme",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./preset": {
      "types": "./src/preset.ts",
      "default": "./dist/preset.js"
    },
    "./manager": {
      "types": "./src/manager.tsx",
      "default": "./dist/manager.js"
    },
    "./preview": {
      "types": "./src/preview.ts",
      "default": "./dist/preview.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "format": "biome check --write src package.json tsconfig.json tsconfig.build.json README.md",
    "lint": "biome check src package.json tsconfig.json tsconfig.build.json README.md",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "storybook": "^10.4.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14"
  }
}
