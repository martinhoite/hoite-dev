{
  "$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
  "files": {
    "includes": [
      "**",
      "!**/.nuxt",
      "!**/.nuxt/**",
      "!**/.output",
      "!**/.output/**",
      "!**/.turbo",
      "!**/.turbo/**",
      "!**/dist",
      "!**/dist/**",
      "!**/node_modules",
      "!**/node_modules/**",
      "!**/pnpm-lock.yaml"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "arrowParentheses": "always",
      "jsxQuoteStyle": "single",
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "json": {
    "formatter": {
      "enabled": true
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "noImportantStyles": "off"
      },
      "correctness": {
        "noUnknownMediaFeatureName": "off"
      },
      "style": {
        "useBlockStatements": "on",
        "useImportType": "on"
      },
      "suspicious": {
        "noConsole": "off",
        "noShorthandPropertyOverrides": "off",
        "noUnknownAtRules": "off"
      }
    }
  }
}
