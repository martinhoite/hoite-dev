{
  "name": "hoite-dev",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "pnpm": ">=10.0.0",
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "pnpm run dev:site:nuxt",
    "frontend-docs:prepare": "pnpm --filter @hoite-dev/ui run build && pnpm --filter @hoite-dev/umbraco-client run build",
    "dev:frontend-docs": "pnpm run frontend-docs:prepare && turbo run dev --filter=@hoite-dev/frontend-docs-hub --filter=@hoite-dev/frontend-docs-design-system-react --filter=@hoite-dev/frontend-docs-design-system-vue --filter=@hoite-dev/frontend-docs-site-nuxt-components",
    "dev:frontend-docs:hub": "turbo dev --filter=@hoite-dev/frontend-docs-hub",
    "dev:frontend-docs:design-system-react": "turbo dev --filter=@hoite-dev/frontend-docs-design-system-react",
    "dev:frontend-docs:design-system-vue": "turbo dev --filter=@hoite-dev/frontend-docs-design-system-vue",
    "dev:frontend-docs:site-nuxt-components": "turbo dev --filter=@hoite-dev/frontend-docs-site-nuxt-components",
    "docker:frontend-docs": "docker build -f apps/frontend-docs/hub/Dockerfile -t hoite-frontend-docs . && docker run --rm -p 8080:80 hoite-frontend-docs",
    "dev:site:nuxt": "turbo dev --filter=@hoite-dev/site-nuxt",
    "format": "turbo format",
    "generate:content:umbraco": "node ./scripts/generate-umbraco-client.mjs",
    "lint": "turbo lint",
    "prepare": "husky",
    "readme:check-versions": "node ./scripts/sync-readme-versions.mjs --check",
    "readme:sync-versions": "node ./scripts/sync-readme-versions.mjs",
    "typecheck": "turbo typecheck",
    "verify:commit": "biome check --staged --no-errors-on-unmatched --files-ignore-unknown=true",
    "verify:versions": "pnpm run readme:check-versions",
    "verify:push": "pnpm run typecheck",
    "deps:outdated": "pnpm outdated -r",
    "deps:upgrade": "pnpm dlx npm-check-updates --workspaces -u"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/node": "24.12.0",
    "husky": "^9.1.7",
    "openapi-typescript": "^7.13.0",
    "tsup": "^8.5.1",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3"
  }
}
