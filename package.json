{
  "name": "hoite-dev",
  "private": true,
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "apps/site-nuxt",
    "apps/frontend-docs/*",
    "packages/*"
  ],
  "engines": {
    "npm": ">=10.0.0",
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "npm run dev:site:nuxt",
    "frontend-docs:prepare": "npm run build --workspace @hoite-dev/ui && npm run build --workspace @hoite-dev/umbraco-client",
    "dev:frontend-docs": "npm run frontend-docs:prepare && npm-run-all --parallel dev:frontend-docs:hub dev:frontend-docs:design-system-react dev:frontend-docs:design-system-vue dev:frontend-docs:site-nuxt-components",
    "dev:frontend-docs:hub": "turbo dev --filter=@hoite-dev/frontend-docs-hub",
    "dev:frontend-docs:design-system-react": "turbo dev --filter=@hoite-dev/frontend-docs-design-system-react",
    "dev:frontend-docs:design-system-vue": "turbo dev --filter=@hoite-dev/frontend-docs-design-system-vue",
    "dev:frontend-docs:site-nuxt-components": "turbo dev --filter=@hoite-dev/frontend-docs-site-nuxt-components",
    "docker:frontend-docs": "docker build -f apps/frontend-docs/hub/Dockerfile -t hoite-frontend-docs . && docker run --rm -p 8080:80 hoite-frontend-docs",
    "dev:site:nuxt": "turbo dev --filter=@hoite-dev/site-nuxt",
    "format": "turbo format",
    "generate:content:umbraco": "node ./scripts/generate-umbraco-client.mjs",
    "lint": "turbo lint",
    "prepare": "husky",
    "readme:check-versions": "node ./scripts/sync-readme-versions.mjs --check",
    "readme:sync-versions": "node ./scripts/sync-readme-versions.mjs",
    "typecheck": "turbo typecheck",
    "verify:commit": "biome check --staged --no-errors-on-unmatched --files-ignore-unknown=true",
    "verify:versions": "npm run readme:check-versions",
    "verify:push": "npm run typecheck",
    "check-updates": "npx npm-check-updates -u"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/node": "24.12.0",
    "husky": "^9.1.7",
    "npm-run-all": "^4.1.5",
    "openapi-typescript": "^7.13.0",
    "tsup": "^8.5.1",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3"
  }
}
