{
  "name": "hoite-dev",
  "private": true,
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "npm": ">=10.0.0",
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "npm run dev:nuxt",
    "dev:nuxt": "turbo dev --filter=@hoite-dev/nuxt-app",
    "format": "turbo format",
    "generate:api": "turbo run generate --filter=@hoite-dev/api-client",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@biomejs/biome": "^2.4.9",
    "openapi-typescript": "^7.13.0",
    "tsup": "^8.5.1",
    "turbo": "^2.8.21",
    "typescript": "^5.9.3"
  }
}
