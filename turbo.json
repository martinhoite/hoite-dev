{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "package.json",
    "turbo.json",
    "tsconfig.base.json",
    "biome.json"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        ".nuxt/**",
        ".output/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "format": {
      "outputs": []
    },
    "generate": {
      "outputs": [
        "openapi/**",
        "src/generated/**"
      ]
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": [
        "^typecheck"
      ],
      "outputs": []
    }
  }
}
