{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["package.json", "turbo.json", "tsconfig.base.json", "biome.jsonc"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".nuxt/**", ".output/**", "storybook-static/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "format": {
      "outputs": []
    },
    "generate": {
      "outputs": ["openapi/**", "src/generated/**", ".build/generated/**", "dist/**"]
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    }
  }
}
